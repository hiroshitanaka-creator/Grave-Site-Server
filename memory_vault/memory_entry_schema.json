{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Memory Entry v1",
  "type": "object",
  "required": [
    "id",
    "date",
    "tz",
    "entry",
    "summary",
    "mood",
    "topics",
    "people",
    "places",
    "actions",
    "signals",
    "privacy",
    "embedding_text"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "tz": { "type": "string" },
    "entry": { "type": "string" },
    "summary": { "type": "string", "maxLength": 30 },
    "mood": {
      "type": "object",
      "required": ["primary", "secondary", "valence", "arousal", "intensity"],
      "properties": {
        "primary": {
          "type": "string",
          "enum": [
            "joy",
            "gratitude",
            "love",
            "calm",
            "hope",
            "pride",
            "surprise",
            "neutral",
            "boredom",
            "sadness",
            "loneliness",
            "anxiety",
            "fear",
            "anger",
            "disgust",
            "shame",
            "guilt",
            "stress"
          ]
        },
        "secondary": {
          "type": "string",
          "enum": [
            "joy",
            "gratitude",
            "love",
            "calm",
            "hope",
            "pride",
            "surprise",
            "neutral",
            "boredom",
            "sadness",
            "loneliness",
            "anxiety",
            "fear",
            "anger",
            "disgust",
            "shame",
            "guilt",
            "stress"
          ]
        },
        "valence": { "type": "number", "minimum": -1.0, "maximum": 1.0 },
        "arousal": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "intensity": { "type": "integer", "minimum": 1, "maximum": 5 }
      }
    },
    "topics": {
      "type": "array",
      "items": { "type": "string" },
      "maxItems": 5
    },
    "people": { "type": "array", "items": { "type": "string" } },
    "places": { "type": "array", "items": { "type": "string" } },
    "actions": { "type": "array", "items": { "type": "string" } },
    "signals": {
      "type": "object",
      "properties": {
        "sleep": { "type": ["number", "null"] },
        "health": { "type": ["number", "null"] }
      }
    },
    "privacy": { "type": "string", "enum": ["private", "public"] },
    "embedding_text": { "type": "string", "maxLength": 200 }
  }
}
